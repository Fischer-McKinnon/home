# Google OAuth credentials
# Create these at https://console.cloud.google.com/
#   1. Create (or select) a project
#   2. APIs & Services → Credentials → Create OAuth 2.0 Client ID
#   3. Application type: Web application
#   4. Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
#      (add the production URL when deploying to Vercel)
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# NextAuth secret — used to encrypt session JWTs and cookies
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-32-plus-random-characters

# NextAuth base URL (required for production; inferred automatically in dev)
# NEXTAUTH_URL=https://fischermckinnon.com
